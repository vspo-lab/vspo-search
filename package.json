{
  "name": "@vspo/search",
  "private": true,
  "description": "Transcript search system for VTuber content",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sugar-cat7/vspo-search"
  },
  "scripts": {
    "dev:next": "pnpm --filter web dev",
    "dev": "dotenv -e .env.local -- turbo dev",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "biome": "turbo biome",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "test": "docker compose -f compose.test.yaml run --rm --build test-all",
    "test:unit": "docker compose -f compose.test.yaml run --rm --build test-unit",
    "test:integration": "docker compose -f compose.test.yaml run --rm --build test-integration",
    "test:coverage": "docker compose -f compose.test.yaml run --rm --build test-coverage",
    "test:clean": "docker compose -f compose.test.yaml down --rmi local --remove-orphans",
    "storybook": "pnpm --filter web storybook",
    "generate:parquet": "tsx scripts/generate-dummy-parquet.ts",
    "textlint": "textlint \"{README.md,docs/**/*.md}\"",
    "textlint:fix": "textlint --fix \"{README.md,docs/**/*.md}\"",
    "security-scan": "./scripts/security-scan.sh",
    "security-scan:docker": "./scripts/security-scan.sh --docker"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.12",
    "@duckdb/node-api": "1.4.4-r.1",
    "@textlint/textlint-plugin-markdown": "^15.5.2",
    "@types/node": "catalog:",
    "dotenv-cli": "^11.0.0",
    "knip": "^5.82.1",
    "textlint": "^15.5.2",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "turbo": "2.6.3",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.24.0"
}
