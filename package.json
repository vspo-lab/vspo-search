{
	"name": "@vspo/search",
	"private": true,
	"description": "Transcript search system for VTuber content",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/sugar-cat7/vspo-search"
	},
	"scripts": {
		"dev": "dotenv -e .env.local -- turbo dev",
		"build": "turbo build",
		"type-check": "turbo type-check",
		"biome": "turbo biome",
		"biome:check": "turbo biome:check",
		"knip": "knip",
		"knip:fix": "knip --fix",
		"test": "turbo test",
		"storybook": "pnpm --filter web storybook",
		"generate:parquet": "tsx scripts/generate-dummy-parquet.ts",
		"textlint": "textlint \"{README.md,docs/**/*.md}\"",
		"textlint:fix": "textlint --fix \"{README.md,docs/**/*.md}\"",
		"security-scan": "./scripts/security-scan.sh",
		"security-scan:docker": "./scripts/security-scan.sh --docker"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@duckdb/node-api": "1.4.4-r.1",
		"@textlint/textlint-plugin-markdown": "^15.5.2",
		"@types/node": "catalog:",
		"dotenv-cli": "^11.0.0",
		"knip": "^5.82.1",
		"textlint": "^15.5.2",
		"textlint-rule-preset-ja-technical-writing": "^12.0.2",
		"tsup": "catalog:",
		"turbo": "2.6.3",
		"typescript": "catalog:",
		"vitest": "^4.0.18"
	},
	"pnpm": {
		"overrides": {
			"rollup": ">=4.59.0"
		}
	},
	"packageManager": "pnpm@10.24.0"
}
